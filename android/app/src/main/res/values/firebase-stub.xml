<?xml version="1.0" encoding="utf-8"?>
<!--
    Firebase auto-init stub.

    The @capacitor/push-notifications plugin pulls in firebase-messaging
    as a transitive Gradle dependency. Firebase ships a ContentProvider
    (`com.google.firebase.provider.FirebaseInitProvider`) that runs at
    app start and calls FirebaseApp.initializeApp(). That call reads
    a handful of string resources — primarily `google_app_id` — that
    are normally generated by the `com.google.gms.google-services`
    Gradle plugin from `android/app/google-services.json`.

    Without google-services.json, those resources don't exist and the
    app crashes on startup with:

        IllegalStateException: Default FirebaseApp is not initialized
        in this process. Make sure to call FirebaseApp.initializeApp(Context)
        first.

    To keep dogfood builds bootable while Firebase isn't fully wired
    up yet, we ship a stub `google_app_id` (and friends) here. Android
    resource merging puts the google-services-plugin's generated values
    LAST, so once a real google-services.json is dropped in, its
    values override these stubs — no removal needed.

    Push delivery obviously won't work until Firebase is properly
    configured, but the rest of the app will run.
-->
<resources>
    <!-- The ID Firebase Core checks for. Format is
         `<projectNumber>:<appNumber>:android:<hex>`. The values are
         intentionally zero-filled so it's obvious they're a stub. -->
    <string name="google_app_id" translatable="false">1:000000000000:android:0000000000000000</string>

    <!-- Used by FCM if it tries to send to GCM directly (legacy). -->
    <string name="gcm_defaultSenderId" translatable="false">000000000000</string>

    <!-- Project metadata strings other Firebase modules sometimes read. -->
    <string name="project_id" translatable="false">breeze-os-placeholder</string>
    <string name="google_api_key" translatable="false">stub</string>
    <string name="google_crash_reporting_api_key" translatable="false">stub</string>
    <string name="firebase_database_url" translatable="false"></string>
</resources>
