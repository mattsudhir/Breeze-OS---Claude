{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/chat",                     "destination": "/api/chat" },
    { "source": "/api/tts",                      "destination": "/api/tts" },
    { "source": "/api/stt",                      "destination": "/api/stt" },
    { "source": "/api/cliq",                     "destination": "/api/cliq" },
    { "source": "/api/notify",                   "destination": "/api/notify" },
    { "source": "/api/vapi-webhook",             "destination": "/api/vapi-webhook" },
    { "source": "/api/db-health",                "destination": "/api/db-health" },
    { "source": "/api/db-migrate",               "destination": "/api/db-migrate" },
    { "source": "/api/admin/owners",             "destination": "/api/admin/owners" },
    { "source": "/api/admin/properties",         "destination": "/api/admin/properties" },
    { "source": "/api/admin/property-utilities", "destination": "/api/admin/property-utilities" },
    { "source": "/api/admin/utility-providers",  "destination": "/api/admin/utility-providers" },
    { "source": "/api/admin/seed",               "destination": "/api/admin/seed" },
    { "source": "/api/(.*)",                     "destination": "/api/rentmanager" }
  ],
  "functions": {
    "api/rentmanager.js":                { "maxDuration": 30 },
    "api/chat.js":                       { "maxDuration": 45 },
    "api/cliq.js":                       { "maxDuration": 45 },
    "api/notify.js":                     { "maxDuration": 15 },
    "api/tts.js":                        { "maxDuration": 30 },
    "api/stt.js":                        { "maxDuration": 30 },
    "api/vapi-webhook.js":               { "maxDuration": 30 },
    "api/db-health.js":                  { "maxDuration": 10 },
    "api/db-migrate.js":                 { "maxDuration": 60 },
    "api/admin/owners.js":               { "maxDuration": 15 },
    "api/admin/properties.js":           { "maxDuration": 15 },
    "api/admin/property-utilities.js":   { "maxDuration": 15 },
    "api/admin/utility-providers.js":    { "maxDuration": 15 },
    "api/admin/seed.js":                 { "maxDuration": 15 }
  }
}
