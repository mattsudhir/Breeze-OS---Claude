{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/chat",     "destination": "/api/chat" },
    { "source": "/api/tts",      "destination": "/api/tts" },
    { "source": "/api/stt",      "destination": "/api/stt" },
    { "source": "/api/cliq-bot", "destination": "/api/cliq-bot" },
    { "source": "/api/(.*)",     "destination": "/api/rentmanager" }
  ],
  "functions": {
    "api/rentmanager.js": { "maxDuration": 30 },
    "api/chat.js":        { "maxDuration": 45 },
    "api/tts.js":         { "maxDuration": 30 },
    "api/stt.js":         { "maxDuration": 30 },
    "api/cliq-bot.js":    { "maxDuration": 45 }
  }
}
