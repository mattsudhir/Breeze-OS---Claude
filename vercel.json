{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/chat",                          "destination": "/api/chat" },
    { "source": "/api/tts",                           "destination": "/api/tts" },
    { "source": "/api/stt",                           "destination": "/api/stt" },
    { "source": "/api/cliq",                          "destination": "/api/cliq" },
    { "source": "/api/notify",                        "destination": "/api/notify" },
    { "source": "/api/upload",                        "destination": "/api/upload" },
    { "source": "/api/notifications",                 "destination": "/api/notifications" },
    { "source": "/api/follows",                       "destination": "/api/follows" },
    { "source": "/api/data",                          "destination": "/api/data" },
    { "source": "/api/webhooks/appfolio",             "destination": "/api/webhooks/appfolio" },
    { "source": "/api/vapi-webhook",                  "destination": "/api/vapi-webhook" },
    { "source": "/api/db-health",                     "destination": "/api/db-health" },
    { "source": "/api/db-migrate",                    "destination": "/api/db-migrate" },
    { "source": "/api/admin/owners",                  "destination": "/api/admin/owners" },
    { "source": "/api/admin/properties",              "destination": "/api/admin/properties" },
    { "source": "/api/admin/property-utilities",      "destination": "/api/admin/property-utilities" },
    { "source": "/api/admin/utility-providers",       "destination": "/api/admin/utility-providers" },
    { "source": "/api/admin/seed",                    "destination": "/api/admin/seed" },
    { "source": "/api/admin/assign-providers-by-city", "destination": "/api/admin/assign-providers-by-city" },
    { "source": "/api/admin/bulk-import",             "destination": "/api/admin/bulk-import" },
    { "source": "/api/admin/property-utilities-bulk", "destination": "/api/admin/property-utilities-bulk" },
    { "source": "/api/admin/move-events",             "destination": "/api/admin/move-events" },
    { "source": "/api/admin/grid-import",             "destination": "/api/admin/grid-import" },
    { "source": "/api/admin/backfill-unit-ids",       "destination": "/api/admin/backfill-unit-ids" },
    { "source": "/api/admin/zoho-mcp-ping",           "destination": "/api/admin/zoho-mcp-ping" },
    { "source": "/api/admin/appfolio-sync",           "destination": "/api/admin/appfolio-sync" },
    { "source": "/api/admin/generate-vapid-keys",     "destination": "/api/admin/generate-vapid-keys" },
    { "source": "/api/admin/test-notification",       "destination": "/api/admin/test-notification" },
    { "source": "/api/push-subscriptions",            "destination": "/api/push-subscriptions" },
    { "source": "/api/category-subscriptions",        "destination": "/api/category-subscriptions" },
    { "source": "/api/issue-gl-mappings",             "destination": "/api/issue-gl-mappings" },
    { "source": "/api/human-tasks",                   "destination": "/api/human-tasks" },
    { "source": "/api/cron/process-tasks",            "destination": "/api/cron/process-tasks" },
    { "source": "/api/cron/appfolio-reconcile",       "destination": "/api/cron/appfolio-reconcile" },
    { "source": "/api/cron/probe-integrations",       "destination": "/api/cron/probe-integrations" },

    { "source": "/api/admin/run-reimport",            "destination": "/api/admin/run-reimport" },
    { "source": "/api/admin/smoke-test",              "destination": "/api/admin/smoke-test" },
    { "source": "/api/admin/recent-errors",           "destination": "/api/admin/recent-errors" },
    { "source": "/api/admin/debug-units-breakdown",   "destination": "/api/admin/debug-units-breakdown" },
    { "source": "/api/admin/list-tenants",            "destination": "/api/admin/list-tenants" },
    { "source": "/api/admin/get-tenant",              "destination": "/api/admin/get-tenant" },
    { "source": "/api/admin/wipe-directory-data",     "destination": "/api/admin/wipe-directory-data" },
    { "source": "/api/admin/import-appfolio-properties", "destination": "/api/admin/import-appfolio-properties" },
    { "source": "/api/admin/import-appfolio-units",   "destination": "/api/admin/import-appfolio-units" },
    { "source": "/api/admin/sync-appfolio-leases-all", "destination": "/api/admin/sync-appfolio-leases-all" },
    { "source": "/api/admin/sync-appfolio-leases-one", "destination": "/api/admin/sync-appfolio-leases-one" },
    { "source": "/api/admin/sync-appfolio-tickets",   "destination": "/api/admin/sync-appfolio-tickets" },
    { "source": "/api/admin/debug-appfolio-auth",     "destination": "/api/admin/debug-appfolio-auth" },
    { "source": "/api/admin/debug-data-integrity",    "destination": "/api/admin/debug-data-integrity" },
    { "source": "/api/admin/debug-leases-state",      "destination": "/api/admin/debug-leases-state" },
    { "source": "/api/admin/dedupe-properties",       "destination": "/api/admin/dedupe-properties" },
    { "source": "/api/admin/dedupe-units",            "destination": "/api/admin/dedupe-units" },
    { "source": "/api/admin/backfill-appfolio-property-ids", "destination": "/api/admin/backfill-appfolio-property-ids" },
    { "source": "/api/admin/backfill-appfolio-unit-ids", "destination": "/api/admin/backfill-appfolio-unit-ids" },
    { "source": "/api/admin/list-integration-health", "destination": "/api/admin/list-integration-health" },
    { "source": "/api/admin/probe-integrations",      "destination": "/api/admin/probe-integrations" },
    { "source": "/api/admin/import-appfolio-property", "destination": "/api/admin/import-appfolio-property" },

    { "source": "/api/(.*)",                          "destination": "/api/rentmanager" }
  ],
  "functions": {
    "api/rentmanager.js":                     { "maxDuration": 30 },
    "api/chat.js":                            { "maxDuration": 120 },
    "api/cliq.js":                            { "maxDuration": 45 },
    "api/notify.js":                          { "maxDuration": 15 },
    "api/upload.js":                          { "maxDuration": 30 },
    "api/notifications.js":                   { "maxDuration": 15 },
    "api/follows.js":                         { "maxDuration": 15 },
    "api/data.js":                            { "maxDuration": 60 },
    "api/webhooks/appfolio.js":               { "maxDuration": 30 },
    "api/tts.js":                             { "maxDuration": 30 },
    "api/stt.js":                             { "maxDuration": 30 },
    "api/vapi-webhook.js":                    { "maxDuration": 30 },
    "api/db-health.js":                       { "maxDuration": 10 },
    "api/db-migrate.js":                      { "maxDuration": 60 },
    "api/admin/owners.js":                    { "maxDuration": 15 },
    "api/admin/properties.js":                { "maxDuration": 15 },
    "api/admin/property-utilities.js":        { "maxDuration": 15 },
    "api/admin/utility-providers.js":         { "maxDuration": 15 },
    "api/admin/seed.js":                      { "maxDuration": 15 },
    "api/admin/assign-providers-by-city.js":  { "maxDuration": 30 },
    "api/admin/bulk-import.js":               { "maxDuration": 60 },
    "api/admin/property-utilities-bulk.js":   { "maxDuration": 30 },
    "api/admin/move-events.js":               { "maxDuration": 30 },
    "api/admin/grid-import.js":               { "maxDuration": 60 },
    "api/admin/backfill-unit-ids.js":         { "maxDuration": 60 },
    "api/admin/zoho-mcp-ping.js":             { "maxDuration": 15 },
    "api/admin/appfolio-sync.js":             { "maxDuration": 300 },
    "api/admin/generate-vapid-keys.js":       { "maxDuration": 10 },
    "api/admin/test-notification.js":         { "maxDuration": 15 },
    "api/push-subscriptions.js":              { "maxDuration": 15 },
    "api/category-subscriptions.js":          { "maxDuration": 15 },
    "api/issue-gl-mappings.js":               { "maxDuration": 15 },
    "api/human-tasks.js":                     { "maxDuration": 15 },
    "api/cron/process-tasks.js":              { "maxDuration": 60 },
    "api/cron/appfolio-reconcile.js":         { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/cron/process-tasks",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/appfolio-reconcile",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/probe-integrations",
      "schedule": "0 */4 * * *"
    }
  ]
}
