# Copy to .env and fill in real values. .env is gitignored.
#
# These match the env vars consumed by the /api/*.js handlers. Anything
# left blank will surface as a 500 from the specific handler that needs
# it, not a startup crash.

# ── Core LLM + voice ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Property data backends ──────────────────────────────────────────
# AppFolio (the default Breeze data source)
APPFOLIO_CLIENT_ID=
APPFOLIO_CLIENT_SECRET=
APPFOLIO_DEVELOPER_ID=

# Rent Manager (used by /api/rentmanager + the rm-demo backend)
RM_BASE_URL=
RM_USERNAME=
RM_PASSWORD=

# Zoho MCP (alternate data source)
ZOHO_MCP_SERVER_URL=

# ── Notifications ───────────────────────────────────────────────────
ZOHO_CLIQ_WEBHOOK_URL=

# Firebase Cloud Messaging for native push notifications. Provide the
# service-account JSON inline (recommended for Fly secrets) or mount
# the file and point GOOGLE_APPLICATION_CREDENTIALS at it.
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Voice calling ───────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# ── Admin / ops ─────────────────────────────────────────────────────
BREEZE_ADMIN_TOKEN=

# ── Database ────────────────────────────────────────────────────────
# Compose injects a working default; override here if you want to point
# at a remote Postgres (e.g. Neon, Supabase) instead of the local db
# service.
# DATABASE_URL=
